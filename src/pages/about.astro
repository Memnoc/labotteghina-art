---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base
  title="About — La Botteghina"
  description="La Botteghina is the digital bottega of an Italian painter — old-master technique carried into digital painting."
>
  <section class="about container">
    <header class="reveal">
      <p class="eyebrow">La Botteghina</p>
      <h1 class="about-title">The little workshop</h1>
    </header>

    <div class="about-body reveal">
      <p class="lede">
        In Renaissance Italy, the <em>bottega</em> was where painting was
        learned by hand — pigment, panel, patience.
      </p>
      <p>
        La Botteghina carries that workshop into the present. The brushes are
        digital — a tablet, a stylus, Photoshop — but the discipline is the old
        one: drawing first, light before color, and the long Italian
        conversation between shadow and form.
      </p>
      <p>
        Every work here is painted by hand, stroke by stroke. If one of them
        speaks to you, <a href={`${base}contact/`} class="link-underline">write to the workshop</a> —
        originals and fine-art prints are available on inquiry.
      </p>
    </div>
  </section>
</Base>

<style>
  .about {
    padding-top: clamp(3rem, 9vh, 6rem);
    max-width: 52rem;
  }

  .about-title {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    margin-top: 0.6rem;
  }

  .about-body {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.4rem;
    max-width: var(--measure);
    color: color-mix(in srgb, var(--c-text) 88%, var(--c-muted));
  }

  .about-body p {
    margin: 0;
  }
</style>
