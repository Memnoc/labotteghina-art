---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'works'>;
  sizes?: string;
}

const { work, sizes = '(max-width: 720px) 92vw, 44vw' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}works/${work.id}/`} class="work-card reveal" data-tilt>
  <figure class="work-frame">
    <Image
      src={work.data.cover}
      alt={`${work.data.title} — ${work.data.medium}, ${work.data.year}`}
      widths={[480, 768, 1080]}
      sizes={sizes}
      class="work-image"
    />
    <span class="work-glow" aria-hidden="true"></span>
  </figure>
  <div class="work-label">
    <span class="work-title">{work.data.title}</span>
    <span class="work-year">{work.data.year}</span>
  </div>
</a>

<style>
  .work-card {
    display: block;
    perspective: 900px;
  }

  .work-frame {
    position: relative;
    margin: 0;
    overflow: hidden;
    background: var(--c-surface);
    transition: transform 0.5s var(--ease-out);
    transform-style: preserve-3d;
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.04) inset,
      0 24px 60px -28px rgb(0 0 0 / 0.85);
  }

  .work-card:hover .work-frame {
    transform: rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg)) translateZ(0)
      scale(1.012);
  }

  .work-image {
    width: 100%;
    transition: transform 1.2s var(--ease-out);
  }

  .work-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      40rem circle at var(--glow-x, 50%) var(--glow-y, 50%),
      rgb(201 164 92 / 0.12),
      transparent 45%
    );
    transition: opacity 0.45s var(--ease-out);
  }

  .work-card:hover .work-glow {
    opacity: 1;
  }

  .work-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.9rem;
  }

  .work-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--c-text);
    transition: color 0.3s var(--ease-out);
  }

  .work-card:hover .work-title {
    color: var(--c-gold);
  }

  .work-year {
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    color: var(--c-faint);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card:hover .work-frame {
      transform: none;
    }
  }
</style>
