---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  works: CollectionEntry<'works'>[];
}

const { works } = Astro.props;
const cycle = 7; /* seconds each slide is dominant */
const total = works.length * cycle;
const holdPct = 100 / works.length;
const fadePct = Math.min(6, holdPct / 2);
const heroKeyframes =
  works.length > 1
    ? `@keyframes hero-fade {
  0% { opacity: 0; }
  ${fadePct.toFixed(2)}% { opacity: 1; }
  ${holdPct.toFixed(2)}% { opacity: 1; }
  ${(holdPct + fadePct).toFixed(2)}% { opacity: 0; }
  100% { opacity: 0; }
}`
    : `@keyframes hero-fade { from { opacity: 1; } to { opacity: 1; } }`;
const heroCss = `${heroKeyframes}
.hero-slide { animation-name: hero-fade; }
@media (prefers-reduced-motion: reduce) { .hero-slide { animation-name: none; } }`;
---

<style is:inline set:html={heroCss}></style>

<section class="hero">
  <div class="hero-slides" aria-hidden="true">
    {
      works.map((work, i) => (
        <Image
          src={work.data.cover}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading={i === 0 ? 'eager' : 'lazy'}
          class="hero-slide"
          style={`animation-delay: ${i * cycle}s; animation-duration: ${total}s;`}
        />
      ))
    }
  </div>
  <div class="hero-scrim"></div>
  <div class="hero-content container">
    <p class="eyebrow">Bottega d'arte digitale</p>
    <h1 class="hero-title">La Botteghina</h1>
    <p class="lede">
      Old-master Italian painting, made with modern hands.
    </p>
    <a href="#wall" class="hero-cue" aria-label="Scroll to the works">
      <span class="hero-cue-line"></span>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: max(88svh, 34rem);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-slides,
  .hero-slides :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-slides :global(img) {
    object-fit: cover;
    opacity: 0;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: opacity;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--c-bg) 0%, transparent 45%),
      linear-gradient(to bottom, color-mix(in srgb, var(--c-bg) 55%, transparent), transparent 30%),
      radial-gradient(120% 90% at 50% 100%, color-mix(in srgb, var(--c-bg) 35%, transparent), transparent 60%);
  }

  .hero-content {
    position: relative;
    width: 100%;
    padding-bottom: clamp(3rem, 9vh, 6rem);
  }

  .hero-title {
    font-size: clamp(3rem, 9vw, 6.5rem);
    letter-spacing: 0.01em;
    margin-block: 0.4rem 0.6rem;
    text-shadow: 0 2px 40px rgb(0 0 0 / 0.55);
  }

  .hero-cue {
    display: inline-block;
    margin-top: 2.5rem;
  }

  .hero-cue-line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(var(--c-gold), transparent);
    animation: cue-drift 2.6s ease-in-out infinite;
  }

  @keyframes cue-drift {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(10px); opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slides :global(img) {
      animation: none;
    }
    .hero-slides :global(img:first-child) {
      opacity: 1;
    }
    .hero-cue-line {
      animation: none;
    }
  }
</style>
